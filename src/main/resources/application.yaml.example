spring:
  datasource:
    url: 
    username: 
    password: 
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate: 
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect

  application:
    name: auth-api
jwt:
  secret:
  expiration: 86400000